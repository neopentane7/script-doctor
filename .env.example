# ──────────────────────────────────────────────────────────────
#  Script Doctor — Environment Variables
# ──────────────────────────────────────────────────────────────
#  Copy this file to `.env` and fill in your actual values.
#
#  cp .env.example .env
# ──────────────────────────────────────────────────────────────

# Google Gemini API key (Outliner + Writer) — https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Groq API key (Critic) — free at https://console.groq.com/keys
# The critic runs on Groq's free Llama 3.3 70B by default: a different, stricter
# model family than the Gemini writer, which reduces LLM-judge self-bias and
# actually drives the revision loop. Required unless you set CRITIC_PROVIDER=google.
GROQ_API_KEY=your_groq_api_key_here

# ── Optional: critic provider / model ─────────────────────────
# CRITIC_PROVIDER=groq                 # "groq" (default) or "google"
# CRITIC_MODEL=llama-3.3-70b-versatile # Groq model, or a gemini-* model if google

# ── Optional: Google model overrides (Outliner / Writer) ──────
# Defaults are gemini-2.5-flash (free tier). gemini-2.5-pro has ZERO free quota —
# only use it if the project behind your key has billing enabled.
# OUTLINER_MODEL=gemini-2.5-flash
# WRITER_MODEL=gemini-2.5-flash

# ── Optional: web server concurrency limits ───────────────────
# MAX_CONCURRENT_JOBS=2   # pipelines running at once
# MAX_ACTIVE_JOBS=8       # running + queued before new requests get 429

# ── Optional: LangSmith tracing (observability) ───────────────
# When enabled, every agent call is auto-traced (tokens, latency, cost) in the
# LangSmith UI. Get a free key at https://smith.langchain.com/settings
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=script-doctor
